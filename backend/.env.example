ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SMTP settings for sending test emails
SMTP_EMAIL_NAME=Hari Prasad
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=your-sending-account@gmail.com
SMTP_PASS=your-app-password-here

# Comma-separated list of Gmail test accounts to check
TEST_ACCOUNTS=test1@gmail.com,test2@gmail.com,test3@gmail.com

# How long to wait for email delivery before checking (seconds)
CHECK_DELAY_SECONDS=10

# Maximum number of rewrite iterations before giving up
MAX_ITERATIONS=10

# Directory to store Gmail OAuth tokens (auto-created, one file per authorized account)
GMAIL_CREDENTIALS_DIR=./gmail_credentials

# Google OAuth app credentials
# Get these from Google Cloud Console → APIs & Services → Credentials → your OAuth client
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
